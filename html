<!-- ══════════════════════════════
     FULLSCREEN EMDR
══════════════════════════════ -->
<div id="fs-emdr">
  <p class="fs-intent" id="fs-intent">—</p>
  <div class="fs-track">
    <div class="fs-rail"></div>
    <div id="fs-ball"></div>
  </div>
  <div class="fs-hint" id="fs-hint">Folge dem goldenen Licht · Augen bewegen · Kopf bleibt gerade</div>
  <button class="fs-stop" onclick="stopFullscreen()">■ &nbsp;Stoppen</button>
</div>

<script>
function goTo(id){
  document.querySelectorAll('.screen').forEach(s=>{s.classList.remove('active');s.style.display='none';});
  const el=document.getElementById(id);
  el.style.display='flex'; el.classList.add('active');
  window.scrollTo(0,0); document.documentElement.scrollTop=0;
}

function updateIntent(val){
  const el=document.getElementById('ep-intent');
  if(el) el.textContent=val.trim()||'Deine Bestellung erscheint hier...';
}

function updateRng(r){
  r.style.setProperty('--p',(((+r.value-1)/9)*100).toFixed(1)+'%');
  const v=document.getElementById('int-val');
  if(v) v.textContent=r.value;
}

let eOn=false,eRaf=null,eT=null,emdrSpd=20;

function toggleEMDR(){ eOn?stopEMDR():startEMDR(); }

function startEMDR(){
  eOn=true; eT=null;
  // Sync intent text to fullscreen
  const intentVal=document.getElementById('intent')?.value?.trim();
  const fsInt=document.getElementById('fs-intent');
  if(fsInt) fsInt.textContent=intentVal||'Folge dem Licht · Halte deine neue Wahrheit';
  // Open fullscreen overlay
  const fs=document.getElementById('fs-emdr');
  if(fs) fs.classList.add('active');
  document.body.style.overflow='hidden';
  // Update small button
  const bt=document.getElementById('ebt');
  if(bt){bt.textContent='■ Stoppen';bt.classList.add('on');}
  eRaf=requestAnimationFrame(anim);
}

function stopEMDR(){
  eOn=false;
  if(eRaf) cancelAnimationFrame(eRaf);
  // Close fullscreen
  const fs=document.getElementById('fs-emdr');
  if(fs) fs.classList.remove('active');
  document.body.style.overflow='';
  // Reset button and hint
  const bt=document.getElementById('ebt'),hint=document.getElementById('ehint');
  if(bt){bt.textContent='▶ Absenden';bt.classList.remove('on');}
  if(hint) hint.textContent='Schließe die Augen · atme tief durch · lass es setzen';
}

function stopFullscreen(){ stopEMDR(); }

function anim(ts){
  if(!eT) eT=ts; if(!eOn) return;
  const period=(42-emdrSpd)*130+1800;
  const t=((ts-eT)%period)/period;
  const f=t<.5?eio(t*2):1-eio((t-.5)*2);
  // Small ball
  const tr=document.querySelector('.etrk'),b=document.getElementById('eb');
  if(tr&&b){ const u=tr.offsetWidth-22; b.style.left=(f*u+11)+'px'; }
  // Fullscreen ball
  const ft=document.querySelector('.fs-track'),fb=document.getElementById('fs-ball');
  if(ft&&fb){ const u2=ft.offsetWidth-32; fb.style.left=(f*u2+16)+'px'; }
  eRaf=requestAnimationFrame(anim);
}
function eio(t){return t<.5?2*t*t:-1+(4-2*t)*t;}

function finish(){
  stopEMDR();
  toast('Bestellung eingegangen ✨');
  setTimeout(()=>goTo('upsell'),900);
}

function repeatSession(){
  document.getElementById('intent').value='';
  document.getElementById('ep-intent').textContent='Deine Bestellung erscheint hier...';
  document.getElementById('r1').value='';
  document.getElementById('r2').value='';
  const rng=document.getElementById('intensity');
  rng.value=7; rng.style.setProperty('--p','67%');
  document.getElementById('int-val').textContent='7';
  document.getElementById('ehint').textContent='Aktiviere zuerst Bild, Emotion und Satz · Dann absenden';
  goTo('session');
}

function toast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2200);
}

window.addEventListener('load',()=>{
  const b=document.getElementById('eb');
  if(b) b.style.left='11px';
});
</script>
